# Secrets / credentials — NEVER commit
.env
.env.*
!.env.example
*.token
*token*.json
secrets/
config/settings.yaml          # live config may contain account ids; only the .example is tracked

# Local cache (Schwab pulls, quotes, chains)
.cache/
*.sqlite
*.sqlite3

# Generated run outputs (may contain account values / masked ids)
reports/runs/*/
!reports/runs/.gitkeep

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
